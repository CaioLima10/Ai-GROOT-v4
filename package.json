{
  "name": "ai-groot-enterprise",
  "version": "2.1.0",
  "description": "Ai-GROOT Enterprise Edition - IA avançada para desenvolvimento de software com NLP e aprendizado real",
  "type": "module",
  "main": "apps/api/dist/server.js",
  "engines": {
    "node": "20.x"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "picomatch": "^2.3.2"
  },
  "scripts": {
    "web-next:dev": "npm --workspace web-next run dev -- -p 3003",
    "web-next:build": "npm --workspace web-next run build",
    "web-next:start": "npm --workspace web-next run start",
    "typecheck:web": "tsc -p apps/web-next/tsconfig.json --noEmit",
    "typecheck:contracts": "tsc -p tsconfig.runtime-contracts.json --noEmit",
    "typecheck:ai-core": "tsc -p tsconfig.ai-core.json --noEmit",
    "typecheck:api-runtime": "tsc -p tsconfig.api-runtime.json --noEmit",
    "typecheck:api-ts": "tsc -p tsconfig.api-ts.json --noEmit",
    "build:api-ts": "tsc -p tsconfig.api-build.json",
    "clean:api-dist": "node -e \"import('fs').then(fs=>fs.promises.rm('apps/api/dist',{recursive:true,force:true}))\"",
    "start:api-ts": "node apps/api/dist/server.js",
    "build:start:api-ts": "npm run clean:api-dist && npm run build:api-ts && npm run start:api-ts",
    "dev:api": "npm run build:start:api-ts",
    "dev:web": "npm --workspace web-next run dev -- -p 3003",
    "dev": "node scripts/dev-new-front.mjs",
    "start": "npm run build:start:api-ts",
    "api:check": "npm --workspace @groot/api run check",
    "enterprise": "npm run build:start:api-ts",
    "doc-reader:install": "node scripts/python-runner.mjs -m pip install -r services/document-reader/requirements.txt",
    "doc-reader:dev": "node scripts/python-runner.mjs -m uvicorn app.main:app --app-dir services/document-reader --host 0.0.0.0 --port 8090 --reload",
    "doc-reader:health": "node scripts/document-reader-health.mjs",
    "doc-reader:metrics": "node scripts/document-reader-metrics.mjs",
    "doc-reader:smoke": "node scripts/document-reader-smoke.mjs",
    "doc-reader:async-smoke": "node scripts/document-reader-async-smoke.mjs",
    "doc-reader:dlq-smoke": "node scripts/document-reader-dlq-smoke.mjs",
    "doc-reader:benchmark": "node scripts/benchmark-document-reader.mjs --dataset benchmarks/document-reader/dataset-template.csv",
    "test:quota-runtime": "node --test tests/upload-quota-runtime.test.js",
    "battery:freemium": "node scripts/battery-freemium.mjs",
    "bootstrap:runtime": "node scripts/bootstrap-runtime.mjs",
    "electron": "electron apps/desktop",
    "smoke:enterprise": "npm run build:api-ts && node scripts/smoke-enterprise.mjs",
    "smoke:documents": "node scripts/smoke-documents.mjs",
    "smoke:safety": "node scripts/smoke-safety.mjs",
    "qa:documents-runtime": "npm run build:api-ts && node scripts/evaluate-document-runtime.mjs",
    "eval:giom": "npm run build:api-ts && node scripts/evaluate-giom-conversation.mjs",
    "eval:giom:audit": "npm run build:api-ts && node scripts/evaluate-giom-stack-audit.mjs",
    "eval:giom:language": "node scripts/evaluate-giom-language-stack.mjs",
    "eval:frontend": "node scripts/evaluate-frontend-ui.mjs",
    "test:frontend-layout": "node scripts/frontend-layout.test.mjs",
    "test:ask-integration": "node --test tests/ask-endpoint.integration.test.js",
    "qa:runtime": "node scripts/runtime-ux-qa.mjs",
    "qa:stress-runtime": "node scripts/runtime-ux-stress.mjs",
    "qa:stress-memory": "node scripts/stress-memory-context.mjs",
    "reliability:chaos": "node scripts/reliability-chaos-ask.mjs",
    "reliability:chaos:stream": "node scripts/reliability-chaos-stream.mjs",
    "reliability:gate": "node scripts/reliability-gate.mjs",
    "reliability:gate:fast": "node scripts/reliability-gate.mjs --profile=fast",
    "reliability:gate:strict": "node scripts/reliability-gate.mjs --profile=strict",
    "reliability:gate:checks-only": "node scripts/reliability-gate.mjs --skip-chaos",
    "poster:a3": "node scripts/render-giom-poster-a3.mjs",
    "prod:stack:up": "docker compose -f deploy/giom-prod/docker-compose.prod.yml up -d --build",
    "prod:stack:down": "docker compose -f deploy/giom-prod/docker-compose.prod.yml down",
    "prod:stack:stress": "powershell -ExecutionPolicy Bypass -File deploy/giom-prod/qa/stress-memory-prod.ps1",
    "prod:stack:run": "powershell -ExecutionPolicy Bypass -File deploy/giom-prod/deploy/run-giom.ps1",
    "bench:ask-latency": "node scripts/benchmark-ask-latency.mjs",
    "ops:check": "node scripts/ops-runtime-check.mjs",
    "ops:check:strict": "node scripts/ops-runtime-check.mjs --strict",
    "ops:watch": "node scripts/ops-runtime-check.mjs --watch --interval=20",
    "ops:supervisor": "npm run build:api-ts && node scripts/ops-supervisor.mjs",
    "memory:backup": "node scripts/giom-memory-backup.mjs backup",
    "memory:verify": "node scripts/giom-memory-backup.mjs verify",
    "memory:list": "node scripts/giom-memory-backup.mjs list",
    "memory:restore": "node scripts/giom-memory-backup.mjs restore",
    "memory:pre-deploy": "node scripts/giom-memory-backup.mjs pre-deploy",
    "audit:enterprise:routes:parity": "node scripts/check-enterprise-route-registrar-parity.mjs",
    "smoke:enterprise:routes:v1": "node scripts/smoke-enterprise-routes-v1.mjs",
    "smoke:enterprise:routes:built:v1": "npm run build:api-ts && node scripts/smoke-enterprise-routes-built-v1.mjs",
    "smoke:enterprise:routes:built:admin:v1": "npm run build:api-ts && node scripts/smoke-enterprise-routes-built-v1.mjs --admin=true",
    "verify:enterprise:routes:v1": "npm run audit:enterprise:routes:parity && npm run smoke:enterprise:routes:v1 && npm run smoke:enterprise:routes:built:admin:v1",
    "kill-port": "npx kill-port 3001 3002 3003",
    "test": "node --test tests/*.test.js scripts/*.test.mjs scripts/test-time-gates.mjs scripts/test-time-gates-ask-http.mjs",
    "lint": "npm --workspace web-next run lint",
    "logs": "tail -f logs/app.log",
    "metrics": "curl http://localhost:3001/metrics",
    "health": "curl http://localhost:3001/health",
    "docker:build": "docker build -t ai-groot-enterprise .",
    "docker:run": "docker run -p 3000:3000 --env-file .env ai-groot-enterprise",
    "docker:compose": "docker-compose up -d",
    "docker:logs": "docker-compose logs -f",
    "deploy:zeabur": "echo 'Configure no dashboard Zeabur'",
    "deploy:render": "echo 'Configure no dashboard Render'",
    "deploy:oracle": "chmod +x deploy/oracle-cloud.sh && ./deploy/oracle-cloud.sh",
    "ai:test": "node debug-apis.js",
    "ai:train": "node core/aiTraining.js",
    "knowledge:rebuild": "node scripts/rebuild-remote-embeddings.js",
    "knowledge:ingest": "node scripts/ingest-knowledge.js",
    "knowledge:next-step": "node scripts/knowledge-next-step.mjs",
    "knowledge:curated": "node scripts/ingest-curated.js",
    "knowledge:free-sources": "node scripts/bootstrap-free-sources.mjs",
    "knowledge:free-sources:ingest": "node scripts/bootstrap-free-sources.mjs --ingest",
    "knowledge:pdf-library": "node scripts/ingest-private-pdf-library.mjs",
    "knowledge:private-library": "node scripts/ingest-private-library.mjs",
    "knowledge:private-library:topics": "node scripts/ingest-private-library.mjs --topics-file knowledge/docs/private-library-topics.json --rights user_provided_or_public_domain",
    "knowledge:audit": "node scripts/audit-knowledge-supabase.mjs",
    "knowledge:health": "node scripts/knowledge-health-report.mjs",
    "knowledge:curate": "node scripts/curate-knowledge-quality.mjs",
    "knowledge:generate-language-pack": "node scripts/generate-language-conversation-pack.mjs",
    "knowledge:generate-mega-pack": "node scripts/generate-giom-mega-pack.mjs",
    "knowledge:generate-targeted-pack": "node scripts/generate-giom-targeted-pack.mjs",
    "knowledge:generate-robust-real-pack": "node scripts/generate-giom-robust-real-pack.mjs",
    "knowledge:scale-100k": "node scripts/scale-knowledge-100k.mjs",
    "knowledge:bible-index": "node scripts/build-bible-reference-index.mjs",
    "yvp:bibles": "node scripts/yvp-bibles.js",
    "evolve": "node -e \"import('./grootCore.js').then(({ grootCore }) => grootCore.evolve())\"",
    "status": "node -e \"import('./grootCore.js').then(({ grootCore }) => grootCore.getStatus().then(console.log))\"",
    "reset": "node -e \"import('./grootCore.js').then(({ grootCore }) => grootCore.reset().then(console.log))\""
  },
  "keywords": [
    "ai",
    "machine-learning",
    "consciousness",
    "vector-memory",
    "autonomous",
    "evolution",
    "enterprise",
    "groot",
    "developer",
    "assistant",
    "debug",
    "nodejs",
    "copilot-alternative",
    "nlp",
    "code-analysis",
    "rag"
  ],
  "author": "Gabriel Lima de Souza",
  "license": "MIT",
  "dependencies": {
    "@huggingface/inference": "^4.13.15",
    "@napi-rs/canvas": "^0.1.97",
    "@tesseract.js-data/eng": "^1.0.0",
    "@tesseract.js-data/por": "^1.0.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.7.4",
    "compromise": "^14.10.0",
    "cors": "^2.8.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "docx": "^9.5.1",
    "dotenv": "^16.3.1",
    "electron": "^41.0.2",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "express-slow-down": "^2.1.0",
    "helmet": "^8.0.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.11.0",
    "natural": "^6.12.0",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^5.5.207",
    "pdfkit": "^0.17.2",
    "pptxgenjs": "^4.0.1",
    "tesseract.js": "^5.0.5",
    "uuid": "^9.0.1",
    "yauzl": "^2.10.0"
  },
  "optionalDependencies": {
    "@supabase/supabase-js": "^2.99.2",
    "axios": "^1.6.2",
    "openai": "^4.20.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": "20.x"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/CaioLima10/Ai-GROOT-v4.git"
  },
  "bugs": {
    "url": "https://github.com/CaioLima10/Ai-GROOT-v4/issues"
  },
  "homepage": "https://github.com/CaioLima10/Ai-GROOT-v4"
}