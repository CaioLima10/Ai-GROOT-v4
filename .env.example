# AI-GROOT Enterprise 9.0 Professional - Environment Variables

# OpenRouter API Key (obrigatório)
# 👉 https://openrouter.ai/keys
# Formato: sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_KEY=sk-or-v1-sua-key-aqui-com-60-caracteres

# Google Gemini API Key (opcional)
# 👉 https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua-gemini-key-aqui

# Supabase (opcional - para memória online)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-supabase-anon-key

# OpenAI (opcional - para embeddings)
OPENAI_API_KEY=sua-openai-key-aqui

# Porta do servidor
PORT=3000

# Modo de debug
DEBUG=true

# Modo do cérebro (core | quantum)
GROOT_MODE=quantum
