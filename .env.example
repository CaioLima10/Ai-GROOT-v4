# AI-GROOT Enterprise 9.0 Professional - Environment Variables

# OpenRouter API Key (obrigatório)
# 👉 https://openrouter.ai/keys
# Formato: sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_KEY=sk-or-v1-sua-key-aqui-com-60-caracteres

# Groq API Key (opcional)
# 👉 https://console.groq.com/keys
GROQ_API_KEY=sua-groq-key-aqui

# Google Gemini API Key (opcional)
# 👉 https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua-gemini-key-aqui

# Supabase (opcional - para memória online)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-supabase-anon-key
SUPABASE_SERVICE_KEY=sua-supabase-service-key

# OpenAI (opcional - para embeddings)
OPENAI_API_KEY=sua-openai-key-aqui

# YouVersion Platform (Bible API) - opcional
# 👉 https://developers.youversion.com
YVP_APP_KEY=sua-yvp-app-key-aqui
YVP_BIBLE_ID=3034

# Porta do servidor
PORT=3000

# Segurança e deploy
ALLOWED_ORIGINS=http://localhost:3000
TRUST_PROXY=true
REQUEST_LIMIT=4mb
RATE_LIMIT_GLOBAL=600
RATE_LIMIT_ASK=60
SLOWDOWN_AFTER=30
SLOWDOWN_DELAY_MS=350
ADMIN_DASH_KEY=seu-admin-key-aqui

# Modo de debug
DEBUG=true

# Modo do cérebro (core | quantum)
GROOT_MODE=quantum

# Perfil de modelos (fast | balanced | best)
GROOT_MODEL_TIER=balanced

# Modelos por provider (opcional)
GROQ_MODEL=llama-3.1-8b-instant
OPENROUTER_MODEL=google/gemma-2-9b-it:free
GEMINI_MODEL=gemini-1.5-flash

# Resumo de conversas (usar LLM para resumir)
SUMMARY_USE_AI=false
