# GIOM AI — Production Environment Template
# ─────────────────────────────────────────────────────────────────
# FOR RENDER.COM: Set these in the Render dashboard → Environment
# FOR VERCEL:     Optional (future)
# FOR DOCKER:     Copy to .env and run: docker-compose up -d
# FOR LOCAL:      Copy to .env at the workspace root
#
# IMPORTANT: Never commit a filled-in .env file to Git.
# This template file is safe to commit (all values are placeholders).
# ─────────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
GROOT_MODE=quantum
GROOT_AI_PROVIDER=auto

# ── AI Provider Keys (at least ONE required for GIOM to respond) ──
# Priority order: Groq → OpenRouter → Gemini → OpenAI
GROQ_API_KEY=gsk_REPLACE_WITH_YOUR_GROQ_KEY
OPENROUTER_KEY=sk-or-REPLACE_WITH_YOUR_OPENROUTER_KEY
OPENROUTER_API_KEY=sk-or-REPLACE_WITH_YOUR_OPENROUTER_KEY
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_KEY
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_OPENAI_KEY

# ── Model Selection ───────────────────────────────────────────────
GROQ_MODEL=llama-3.1-8b-instant
OPENROUTER_MODEL=openrouter/auto
GEMINI_MODEL=gemini-2.5-flash
OPENAI_MODEL=gpt-4o-mini

# ── Database — Supabase ───────────────────────────────────────────
SUPABASE_URL=https://REPLACE.supabase.co
SUPABASE_ANON_KEY=REPLACE_WITH_ANON_KEY
SUPABASE_SERVICE_KEY=REPLACE_WITH_SERVICE_ROLE_KEY

# ── Security ──────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
CORS_ORIGIN=https://your-giom-frontend.onrender.com

# ── Embeddings ────────────────────────────────────────────────────
EMBEDDINGS_PROVIDER=auto
OLLAMA_ENABLED=false

# ── Frontend (Next.js — set where frontend is hosted) ─────────────
# These NEXT_PUBLIC_ vars are baked in at build time:
NEXT_PUBLIC_BACKEND_PROXY_TARGET=https://giom-backend.onrender.com
# Leave NEXT_PUBLIC_API_BASE_URL empty to use the proxy (recommended):
NEXT_PUBLIC_API_BASE_URL=

# ── Optional ──────────────────────────────────────────────────────
HUGGINGFACE_API_KEY=hf_REPLACE_IF_NEEDED
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3

# ── Time Verification / Freshness Safety ──────────────────────────
TIME_VERIFICATION_ENABLED=true
TIME_VERIFICATION_API_BASE_URL=https://worldtimeapi.org/api/timezone
TIME_VERIFICATION_DEFAULT_ZONE=Etc/UTC
TIME_VERIFICATION_TIMEOUT_MS=2500
TIME_VERIFICATION_CACHE_TTL_MS=60000
SPORTS_UPCOMING_GRACE_MS=900000
SPORTS_LIVE_LOOKBACK_MS=14400000
SPORTS_STALE_SCHEDULE_LOOKBACK_MS=21600000

# SportsDataIO (soccer)
SPORTSDATAIO_API_KEY=bb1ef4b5c9a047cd85057ae197727178
SPORTSDATAIO_API_BASE_URL=https://api.sportsdata.io/v4/soccer
SPORTSDATAIO_INCLUDE_KEY_QUERY=false

# ─────────────────────────────────────────────────────────────────
# GitHub Actions Secrets Required (set in repo Settings → Secrets):
#   GROQ_API_KEY            ← AI provider
#   OPENROUTER_KEY          ← AI provider
#   GEMINI_API_KEY          ← AI provider
#   SUPABASE_URL            ← database
#   SUPABASE_ANON_KEY       ← database
#   SUPABASE_SERVICE_KEY    ← database (service role)
#   JWT_SECRET              ← auth
#   RENDER_DEPLOY_HOOK_URL  ← Render webhook from dashboard
# Optional (only if using Vercel in the future):
#   VERCEL_TOKEN            ← Vercel personal token
#   VERCEL_ORG_ID           ← from `vercel env` CLI
#   VERCEL_PROJECT_ID       ← from `vercel env` CLI
# ─────────────────────────────────────────────────────────────────
