{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": ["apps/web-next/src/*"]
    },
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM"],
    "types": ["node"]
  },
  "include": [
    "packages/shared-config/src/runtimeContracts.js",
    "packages/shared-config/src/questionIntents.js",
    "apps/web-next/src/lib/runtimeContracts.ts",
    "apps/web-next/src/lib/questionIntents.ts",
    "apps/web-next/src/components/messages/types.ts"
  ]
}
